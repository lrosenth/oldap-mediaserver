{
{% if caddy_acme_email | default('') | length > 0 %}
    email {{ caddy_acme_email }}
{% endif %}
{% if caddy_auto_https | default('') | length > 0 %}
    auto_https {{ caddy_auto_https }}
{% endif %}
}

{{ caddy_site_addresses | default([media_domain]) | join(', ') }} {
{% if caddy_tls_internal | default(false) | bool %}    tls internal

{% endif %}
    encode zstd gzip

    @iiif path /iiif/*
    handle @iiif {
        reverse_proxy imageserver:8182
    }

    handle_path /asset/* {
        route {
            @asset_preflight method OPTIONS
            handle @asset_preflight {
                rewrite * /auth/asset{http.request.uri}
                reverse_proxy mediaserver:8000
            }

            @asset_methods not method GET HEAD OPTIONS
            respond @asset_methods "method not allowed" 405

            request_header -X-Oldap-Internal-Path
            request_header -X-Oldap-Content-Type
            request_header -X-Oldap-Content-Disposition
            request_header -X-Oldap-Cors-Allow-Origin
            header -X-Oldap-Internal-Path
            header -X-Oldap-Content-Type
            header -X-Oldap-Content-Disposition
            header -X-Oldap-Cors-Allow-Origin

            forward_auth mediaserver:8000 {
                uri /auth/asset{http.request.uri}
                copy_headers X-Oldap-Internal-Path X-Oldap-Content-Type X-Oldap-Content-Disposition X-Oldap-Cors-Allow-Origin
            }

            @no_internal not header X-Oldap-Internal-Path *
            respond @no_internal "forbidden" 403

            header {
                Content-Type "{http.request.header.X-Oldap-Content-Type}"
                Content-Disposition "{http.request.header.X-Oldap-Content-Disposition}"
                defer
            }

            @asset_cors header X-Oldap-Cors-Allow-Origin *
            header @asset_cors {
                Access-Control-Allow-Origin "{http.request.header.X-Oldap-Cors-Allow-Origin}"
                Access-Control-Allow-Methods "GET, HEAD, OPTIONS"
                Access-Control-Allow-Headers "Authorization, Content-Type"
                Access-Control-Expose-Headers "Content-Disposition"
                Vary "Origin"
                defer
            }

            rewrite * {http.request.header.X-Oldap-Internal-Path}
            root * /
            file_server
        }
    }

    @upload path /upload /upload/*
    handle @upload {
        reverse_proxy mediaserver:8000
    }

    @status path /health /status
    handle @status {
        reverse_proxy mediaserver:8000
    }

    @auth_any path /auth/*
    handle @auth_any {
        respond "not found" 404
    }

    handle {
        respond "not found" 404
    }
}
