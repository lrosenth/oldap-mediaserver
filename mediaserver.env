

# mediaserver.env.example
# -----------------------------------------------------------------------------
# Example environment file for the OLDAP mediaserver stack.
# Copy this file to `mediaserver.env` and adjust values for your environment.
# DO NOT commit mediaserver.env (contains secrets).

# --- Media capability JWT
# Must equal oldap-api's OLDAP_MEDIA_JWT_SECRET, never its access-token key.
OLDAP_MEDIA_JWT_SECRET=04a23e0771387424f660b082a84c0fcb4ed36230bf6ddea30d681ed58c7c4d60

# These values must match oldap-api's token configuration.
OLDAP_JWT_ISSUER=https://oldap.org
OLDAP_JWT_AUDIENCE=oldap-api
OLDAP_MEDIA_JWT_AUDIENCE=oldap-api-media

# --- OLDAP API (public/external URL)
# The mediahelper calls this endpoint to validate/lookup metadata.
OLDAP_API_URL=http://host.docker.internal:8000

# --- Anonymous / fallback user
OLDAP_UNKNOWN_USERID=unknown
OLDAP_UNKNOWN_PASSWORD=

# --- CORS
# Either "*" or comma-separated list of allowed origins.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Storage (host paths mounted into containers)
# Must be absolute host paths.
MEDIA_DATA=/data/images
UPLOADER_IMGDIR=/data/images
