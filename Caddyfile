{
	# Useful for local dev while iterating
	debug
}

:{$CADDY_PORT:8088} {

	encode zstd gzip

	# ----------------------------
	# IIIF -> Cantaloupe
	# ----------------------------
	@iiif path /iiif/*
	handle @iiif {
		reverse_proxy imageserver:8182
	}

	# ----------------------------
	# Asset delivery (non-IIIF)
	# Public:  /asset/<id>[/original|derived]
	# ----------------------------
	handle_path /asset/* {
		route {
			# TEMP DEBUG (must run before forward_auth)
			@asset_debug query debug=1
			respond @asset_debug "rest={http.request.uri} path={http.request.uri.path} query={http.request.uri.query}" 200

			# Ask Flask if this request is allowed and where the file lives.
			# Because we're inside handle_path /asset/*, {http.request.uri} is the remainder:
			#   /<id>[/original|derived][?query]
			forward_auth mediaserver:8000 {
				uri /auth/asset{http.request.uri}
				copy_headers X-Oldap-Internal-Path X-Oldap-Content-Type X-Oldap-Content-Disposition
			}

			# Guard: if auth did not provide an internal path, deny
			@no_internal not header X-Oldap-Internal-Path *
			respond @no_internal "forbidden" 403

			# Rewrite to the internal absolute file path and serve it
			rewrite * {http.request.header.X-Oldap-Internal-Path}
			root * /
			file_server

			# Preserve the Content-Type / Disposition Flask already computed
			header {
				Content-Type "{http.request.header.X-Oldap-Content-Type}"
				Content-Disposition "{http.request.header.X-Oldap-Content-Disposition}"
			}
		}
	}

	# Optional: healthcheck
	handle /health {
		respond "ok" 200
	}

	# ----------------------------
	# Upload -> Flask mediahelper
	# ----------------------------
	@upload path /upload /upload/*
	handle @upload {
		reverse_proxy mediaserver:8000
	}

	# ----------------------------
	# Auth helper (DEV ONLY)
	# Allows calling the forward_auth backend endpoint directly for debugging.
	# In production you typically do NOT expose /auth/* publicly.
	# ----------------------------
	@auth path /auth/*
	handle @auth {
		reverse_proxy mediaserver:8000
	}

	# Default
	handle {
		respond "not found" 404
	}
}