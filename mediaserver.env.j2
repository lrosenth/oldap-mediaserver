

# mediaserver.env.j2
# -----------------------------------------------------------------------------
# This file is rendered by Ansible (Jinja2) and consumed by docker-compose via
# `env_file:`.
#
# Conventions:
#   - Ansible vars (inventory/group_vars): lower_snake_case
#   - Container environment variables:     UPPER_SNAKE_CASE
#
# Notes:
#   - Always define OLDAP_UNKNOWN_PASSWORD (even if empty) to avoid "undefined".
#   - JWT secret should be >= 32 bytes (PyJWT warns for shorter HMAC keys).

# --- Media capability JWT
OLDAP_MEDIA_JWT_SECRET={{ oldap_media_jwt_secret }}
OLDAP_JWT_ISSUER={{ oldap_jwt_issuer | default('https://oldap.org') }}
OLDAP_JWT_AUDIENCE={{ oldap_jwt_audience | default('oldap-api') }}
OLDAP_MEDIA_JWT_AUDIENCE={{ oldap_jwt_audience | default('oldap-api') }}-media

# --- OLDAP API (public/external URL)
# For local docker dev you might use: http://host.docker.internal:8000
OLDAP_API_URL={{ public_api_url }}

# --- Anonymous / fallback user
OLDAP_UNKNOWN_USERID={{ oldap_unknown_userid | default('unknown') }}
OLDAP_UNKNOWN_PASSWORD={{ oldap_unknown_password | default('') }}

# --- CORS
# "*" or comma-separated list of allowed origins.
CORS_ORIGINS={{ cors_origins | default('*') }}

# --- Storage paths inside the containers
# These paths must match what the containers expect (mount points).
# imageserver (Cantaloupe) typically serves from /data/images
# mediahelper uses the same root for writing uploads/derivatives.
MEDIA_DATA={{ media_data_dir | default('/data/images') }}
UPLOADER_IMGDIR={{ uploader_imgdir | default('/data/images') }}
